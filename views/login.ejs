<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Iniciar sesión — Google</title>
  <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Roboto', sans-serif;
      background: #f8f9fa;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      background: #fff;
      border-radius: 28px;
      box-shadow: 0 2px 10px rgba(0,0,0,.12);
      padding: 48px 40px 36px;
      width: 100%;
      max-width: 400px;
      text-align: center;
    }
    .google-logo { margin-bottom: 24px; }
    .google-logo svg { width: 75px; }
    h1 {
      font-family: 'Google Sans', sans-serif;
      font-size: 24px;
      font-weight: 400;
      color: #202124;
      margin-bottom: 8px;
    }
    .subtitle {
      font-size: 16px;
      color: #202124;
      margin-bottom: 8px;
    }
    .hint {
      font-size: 14px;
      color: #5f6368;
      margin-bottom: 32px;
      line-height: 1.5;
    }
    .btn-google {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      width: 100%;
      padding: 12px 24px;
      border-radius: 24px;
      border: 1px solid #dadce0;
      background: #fff;
      font-family: 'Google Sans', sans-serif;
      font-size: 15px;
      font-weight: 500;
      color: #3c4043;
      cursor: pointer;
      text-decoration: none;
      transition: background .15s, box-shadow .15s;
    }
    .btn-google:hover {
      background: #f8f9fa;
      box-shadow: 0 1px 3px rgba(0,0,0,.15);
    }
    .btn-google svg { width: 20px; height: 20px; flex-shrink: 0; }
    .divider {
      display: flex; align-items: center; gap: 12px;
      margin: 24px 0;
    }
    .divider hr { flex: 1; border: none; border-top: 1px solid #e0e0e0; }
    .divider span { font-size: 13px; color: #9aa0a6; }
    .footer-links {
      display: flex;
      justify-content: center;
      gap: 16px;
      margin-top: 28px;
      flex-wrap: wrap;
    }
    .footer-links a {
      font-size: 12px;
      color: #5f6368;
      text-decoration: none;
    }
    .footer-links a:hover { text-decoration: underline; }
    .error-banner {
      background: #fce8e6;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
      color: #c5221f;
      margin-bottom: 20px;
      display: none;
    }
  </style>
</head>
<body>
  <div class="card">
    <!-- Google logo SVG -->
    <div class="google-logo">
      <svg viewBox="0 0 75 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M29.88 12.27c0-.71-.06-1.39-.17-2.04H17.1v3.86h7.17a6.13 6.13 0 0 1-2.66 4.02v3.34h4.3c2.52-2.32 3.97-5.74 3.97-9.18Z" fill="#4285F4"/>
        <path d="M17.1 23.5c3.6 0 6.62-1.19 8.83-3.23l-4.3-3.34c-1.19.8-2.72 1.27-4.53 1.27-3.48 0-6.43-2.35-7.48-5.51H5.17v3.45A13.33 13.33 0 0 0 17.1 23.5Z" fill="#34A853"/>
        <path d="M9.62 12.69a8.04 8.04 0 0 1 0-5.13V4.11H5.17a13.34 13.34 0 0 0 0 11.97l4.45-3.39Z" fill="#FBBC05"/>
        <path d="M17.1 5.04a7.22 7.22 0 0 1 5.1 2l3.82-3.82A12.84 12.84 0 0 0 17.1.75 13.33 13.33 0 0 0 5.17 8.11l4.45 3.45c1.05-3.16 4-5.52 7.48-5.52Z" fill="#EA4335"/>
        <text x="34" y="18" font-family="'Google Sans',sans-serif" font-size="18" fill="#5f6368" font-weight="400">Google</text>
      </svg>
    </div>

    <h1>Iniciar sesión</h1>
    <p class="subtitle">Continuá con tu cuenta de Google</p>
    <p class="hint">Para acceder al servicio necesitás autenticarte con tu cuenta de Google.</p>

    <% if (locals.error) { %>
      <div class="error-banner" style="display:block">
        Error al iniciar sesión. Intentá de nuevo.
      </div>
    <% } %>

    <a href="/auth/google" class="btn-google">
      <svg viewBox="0 0 48 48">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
      </svg>
      Continuar con Google
    </a>

    <div class="divider">
      <hr/><span>o</span><hr/>
    </div>

    <p style="font-size:13px;color:#5f6368;line-height:1.6">
      Al continuar, aceptás los <a href="#" style="color:#1a73e8;text-decoration:none">Términos del Servicio</a> y la
      <a href="#" style="color:#1a73e8;text-decoration:none">Política de Privacidad</a> de Google.
    </p>

    <div class="footer-links">
      <a href="#">Ayuda</a>
      <a href="#">Privacidad</a>
      <a href="#">Términos</a>
    </div>
  </div>
</body>
</html>
